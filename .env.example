# ──────────────────────────────────────────────
# Backend (apps/server) — Express + Socket.IO
# ──────────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000
DATABASE_URL=postgresql://pollcast:pollcast_dev@localhost:5434/pollcast
REDIS_URL=redis://localhost:6379

# JWT — use 64+ char random strings in production
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_REFRESH_SECRET=change-me-to-another-random-64-char-string

# SMTP for email invites
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@pollcast.app

# ──────────────────────────────────────────────
# Frontend (apps/web) — Next.js
# ──────────────────────────────────────────────
# Change these to your production URLs
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
