{
  "name": "pollcast",
  "version": "1.0.0",
  "private": true,
  "description": "Real-Time Live Polling & Q&A Platform",
  "scripts": {
    "postinstall": "npx prisma generate",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:web\"",
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:server": "npm run dev --workspace=apps/server",
    "build": "npm run build --workspace=packages/shared && npm run build --workspace=apps/server && npm run build --workspace=apps/web",
    "build:server": "npm run build --workspace=apps/server",
    "build:web": "npm run build --workspace=apps/web",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "npm run test --workspace=apps/server",
    "test:e2e": "npx playwright test",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "db:migrate": "npx prisma migrate dev",
    "db:deploy": "npx prisma migrate deploy",
    "db:seed": "npx prisma db seed",
    "db:studio": "npx prisma studio",
    "clean": "rm -rf apps/*/dist apps/*/.next node_modules"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@types/nodemailer": "^8.0.1",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "prisma": "^5.14.0",
    "typescript": "^5.4.5"
  },
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.2.1",
    "nodemailer": "^9.0.3"
  }
}
